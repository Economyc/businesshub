rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Companies y todo lo que cuelga de ellas (members, roles, subcolecciones de negocio)
    match /companies/{companyId} {
      allow read, write: if request.auth != null;

      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Settings globales (categories, roles legados, departments)
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
